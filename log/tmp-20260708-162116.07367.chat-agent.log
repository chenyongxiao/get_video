n-items:center;background:var(--card-bg);border:1.5px solid var(--card-border);border-radius:var(--radius-sm);padding:0 16px;transition:border-color .3s}\\n.input-wrapper:focus-within{border-color:var(--primary)}\\n.input-wrapper input{flex:1;background:none;border:none;outline:none;color:var(--text);font-size:15px;padding:16px 0;min-height:52px;width:100%}\\n.input-wrapper input::placeholder{color:var(--text-muted)}\\n.clear-btn{background:none;border:none;color:var(--text-muted);cursor:pointer;padding:4px;display:flex;align-items:center;flex-shrink:0}\\n.download-btn{width:100%;margin-top:12px;padding:16px;background:linear-gradient(135deg,var(--primary),#ff6b35);border:none;border-radius:var(--radius-sm);color:#fff;font-size:16px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:transform .2s,box-shadow .2s;box-shadow:0 4px 16px rgba(254,44,85,.3)}\\n.download-btn:active{transform:scale(.98)}\\n.download-btn:disabled{opacity:.6;cursor:not-allowed;transform:none}\\n.status-section{margin:16px 0}\\n.status-card{background:var(--card-bg);border:1px solid var(--card-border);border-radius:var(--radius);padding:24px;text-align:center}\\n.status-icon{display:flex;align-items:center;justify-content:center;margin-bottom:12px}\\n.spinner{width:32px;height:32px;border:3px solid var(--card-border);border-top-color:var(--primary);border-radius:50%;animation:spin .8s linear infinite}\\n@keyframes spin{to{transform:rotate(360deg)}}\\n.status-text{font-size:15px;color:var(--text-secondary);margin-bottom:12px}\\n.progress-bar{width:100%;height:4px;background:var(--card-border);border-radius:2px;overflow:hidden}\\n.progress-fill{height:100%;width:0%;background:linear-gradient(90deg,var(--primary),#ff6b35);border-radius:2px;transition:width .3s}\\n.result-section{margin:16px 0}\\n.video-card{background:var(--card-bg);border:1px solid var(--card-border);border-radius:var(--radius);overflow:hidden}\\n.video-info{padding:16px}\\n.