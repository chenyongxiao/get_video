2026-07-08 16:28:54.024	DEBUG	ws/server.go:818	write response: {"messages":[{"ConnId":"","content":"{\"status\":\"SUCCESS\",\"content\":\"{\\\"fileSizeInBytes\\\":11317,\\\"totalLines\\\":394,\\\"content\\\":\\\"/**\\\\n * 抖音视频下载器 - 前端逻辑\\\\n */\\\\n\\\\n// DOM 元素\\\\nconst videoUrlInput = document.getElementById('videoUrl');\\\\nconst clearBtn = document.getElementById('clearBtn');\\\\nconst downloadBtn = document.getElementById('downloadBtn');\\\\nconst statusSection = document.getElementById('statusSection');\\\\nconst statusText = document.getElementById('statusText');\\\\nconst statusIcon = document.getElementById('statusIcon');\\\\nconst progressFill = document.getElementById('progressFill');\\\\nconst resultSection = document.getElementById('resultSection');\\\\nconst previewVideo = document.getElementById('previewVideo');\\\\nconst videoTitle = document.getElementById('videoTitle');\\\\nconst videoMeta = document.getElementById('videoMeta');\\\\nconst saveBtn = document.getElementById('saveBtn');\\\\nconst copyBtn = document.getElementById('copyBtn');\\\\nconst historyList = document.getElementById('historyList');\\\\nconst clearHistoryBtn = document.getElementById('clearHistoryBtn');\\\\n\\\\n// 状态\\\\nlet currentVideoUrl = '';\\\\nlet currentVideoInfo = null;\\\\nlet isDownloading = false;\\\\n\\\\n/**\\\\n * Toast 提示\\\\n */\\\\nfunction showToast(message, duration = 2000) {\\\\n    const existing = document.querySelector('.toast');\\\\n    if (existing) existing.remove();\\\\n\\\\n    const toast = document.createElement('div');\\\\n    toast.className = 'toast';\\\\n    toast.textContent = message;\\\\n    document.body.appendChild(toast);\\\\n\\\\n    requestAnimationFrame(() =\\\\u003e {\\\\n        toast.classList.add('show');\\\\n    });\\\\n\\\\n    setTimeout(() =\\\\u003e {\\\\n        toast.classList.remove('show');\\\\n        setTimeout(() =\\\\u003e toast.remove(), 300);\\\\n    }, duration);\\\\n}\\\\n\\\\n/**\\\\n * 格式化时间\\\\n */\\\\nfunction formatTime(date) {\\\\n    const now = new Date();\\\\n    const diff = now - date;\\\\n    const minutes = Math.floor(diff / 60000);\\\\n    const hours = Math.floor(diff / 3600000);\\\\n    const days = Math.floor(diff / 86400000);\\\\n\\\\n    if (minutes \\\\u003c 1) return '刚刚';\\\\n    if (minutes \\\\u003c 60) return `${minutes}分钟前`;\\\\n    if (hours \\\\u003c 24) return `${hours}小时前`;\\\\n    if (days \\\\u003c 7) return `${days}天前`;\\\\n    return date.toLocaleDateString('zh-CN');\\\\n}\\\\n\\\\n/**\\\\n * 设置状态\\\\n */\\\\nfunction setStatus(text, isError = false) {\\\\n    statusText.textContent = text;\\\\n    statusText.className = 'status-text' + (isError ? ' error-text' : '');\\\\n    if (isError) {\\\\n        statusIcon.innerHTML = `\\\\n            \\\\u003csvg viewBox=\\\\\\\"0 0 24 24\\\\\\\" width=\\\\\\\"32\\\\\\\" height=\\\\\\\"32\\\\\\\" style=\\\\\\\"color:#ff5252\\\\\\\"\\\\u003e\\\\n                \\\\u003cpath fill=\\\\\\\"currentColor\\\\\\\" d=\\\\\\\"M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z\\\\\\\"/\\\\u003e\\\\n            \\\\u003c/svg\\\\u003e\\\\n        `;\\\\n    } else {\\\\n        statusIcon.innerHTML = `\\\\u003cdiv class=\\\\\\\"spinner\\\\\\\"\\\\u003e\\\\u003c/div\\\\u003e`;\\\\n    }\\\\n}\\\\n\\\\n/**\\\\n * 设置进度\\\\n */\\\\nfunction setProgress(percent) {\\\\n    progressFill.style.width = `${percent}%`;\\\\n}\\\\n\\\\n/**\\\\n * 显示/隐藏状态\\\\n */\\\\nfunction showStatus(show) {\\\\n    statusSection.style.display = show ? 'block' : 'none';\\\\n}\\\\n\\\\n/**\\\\n * 显示/隐藏结果\\\\n */\\\\nfunction showResult(show) {\\\\n    resultSection.style.display = show ? 'block' : 'none';\\\\n}\\\\n\\\\n/**\\\\n * 加载历史记录\\\\n */\\\\nfunction loadHistory() {\\\\n    try {\\\\n        const history = JSON.parse(localStorage.getItem('douyin_download_history') || '[]');\\\\n        renderHistory(history);\\\\n    } catch {\\\\n        renderHistory([]);\\\\n    }\\\\n}\\\\n\\\\n/**\\\\n * 渲染历史记录\\\\n */\\\\nfunction renderHistory(history) {\\\\n    if (history.length === 0) {\\\\n        historyList.innerHTML = '\\\\u003cdiv class=\\\\\\\"empty-history\\\\\\\"\\\\u003e暂无下载记录\\\\u003c/div\\\\u003e';\\\\n        return;\\\\n    }\\\\n\\\\n    historyList.innerHTML = history.map((item, index) =\\\\u003e `\\\\n        \\\\u003cdiv class=\\\\\\\"history-item\\\\\\\" data-index=\\\\\\\"${index}\\\\\\\"\\\\u003e\\\\n            \\\\u003cdiv class=\\\\\\\"history-thumb\\\\\\\"\\\\u003e\\\\n                \\\\u003csvg viewBox=\\\\\\\"0 0 24 24\\\\\\\" width=\\\\\\\"24\\\\\\\" height=\\\\\\\"24\\\\\\\" fill=\\\\\\\"#666\\\\\\\"\\\\u003e\\\\n                    \\\\u003cpath d=\\\\\\\"M8 5v14l11-7z\\\\\\\"/\\\\u003e\\\\n                \\\\u003c/svg\\\\u003e\\\\n            \\\\u003c/div\\\\u003e\\\\n            \\\\u003cdiv class=\\\\\\\"history-info\\\\\\\"\\\\u003e\\\\n                \\\\u003cdiv class=\\\\\\\"history-name\\\\\\\"\\\\u003e${escapeHtml(item.title || '抖音视频')}\\\\u003c/div\\\\u003e\\\\n                \\\\u003cdiv class=\\\\\\\"history-time\\\\\\\"\\\\u003e${formatTime(new Date(item.time))}\\\\u003c/div\\\\u003e\\\\n            \\\\u003c/div\\\\u003e\\\\n            \\\\u003cbutton class=\\\\\\\"history-delete\\\\\\\" data-index=\\\\\\\"${index}\\\\\\\" onclick=\\\\\\\"event.stopPropagation(); deleteHistory(${index})\\\\\\\"\\\\u003e\\\\n                \\\\u003csvg viewBox=\\\\\\\"0 0 24 24\\\\\\\" width=\\\\\\\"18\\\\\\\" height=\\\\\\\"18\\\\\\\" fill=\\\\\\\"currentColor\\\\\\\"\\\\u003e\\\\n                    \\\\u003cpath d=\\\\\\\"M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z\\\\\\\"/\\\\u003e\\\\n                \\\\u003c/svg\\\\u003e\\\\n            \\\\u003c/button\\\\u003e\\\\n        \\\\u003c/div\\\\u003e\\\\n    `).join('');\\\\n\\\\n    // 点击历史项重新下载\\\\n    document.querySelectorAll('.history-item').forEach(el =\\\\u003e {\\\\n        el.addEventListener('click', function() {\\\\n            const index = parseInt(this.dataset.index);\\\\n            const history = JSON.parse(localStorage.getItem('douyin_download_history') || '[]');\\\\n            const item = history[index];\\\\n            if (item \\\\u0026\\\\u0026 item.url) {\\\\n                videoUrlInput.value = item.url;\\\\n                clearBtn.style.display = 'block';\\\\n                startDownload(item.url);\\\\n            }\\\\n        });\\\\n    });\\\\n}\\\\n\\\\n/**\\\\n * 添加历史记录\\\\n */\\\\nfunction addHistory(title, url) {\\\\n    try {\\\\n        const history = JSON.parse(localStorage.getItem('douyin_download_history') || '[]');\\\\n        // 去重\\\\n        const exists = history.some(item =\\\\u003e item.url === url);\\\\n        if (!exists) {\\\\n            history.unshift({\\\\n                title: title,\\\\n                url: url,\\\\n                time: new Date().toISOString(),\\\\n            });\\\\n            // 最多保留 20 条\\\\n            if (history.length \\\\u003e 20) {\\\\n                history.pop();\\\\n            }\\\\n            localStorage.setItem('douyin_download_history', JSON.stringify(history));\\\\n            renderHistory(history);\\\\n        }\\\\n    } catch {\\\\n        // ignore\\\\n    }\\\\n}\\\\n\\\\n/**\\\\n * 删除历史记录\\\\n */\\\\nfunction deleteHistory(index) {\\\\n    try {\\\\n        const history = JSON.parse(localStorage.getItem('douyin_download_history') || '[]');\\\\n        history.splice(index, 1);\\\\n        localStorage.setItem('douyin_download_history', JSON.stringify(history));\\\\n        renderHistory(history);\\\\n    } catch {\\\\n        // ignore\\\\n    }\\\\n}\\\\n\\\\n/**\\\\n * HTML 转义\\\\n */\\\\nfunction escapeHtml(text) {\\\\n    const div = document.createElement('div');\\\\n    div.textContent = text;\\\\n    return div.innerHTML;\\\\n}\\\\n\\\\n/**\\\\n * 开始下载流程\\\\n */\\\\nasync function startDownload(url) {\\\\n    if (isDownloading) return;\\\\n    isDownloading = true;\\\\n\\\\n    // 禁用按钮\\\\n    downloadBtn.disabled = true;\\\\n    downloadBtn.querySelector('.btn-text').textContent = '解析中...';\\\\n\\\\n    // 显示状态\\\\n    showStatus(true);\\\\n    showResult(false);\\\\n    setStatus('正在解析视频链接...');\\\\n    setProgress(10);\\\\n\\\\n    try {\\\\n        // 步骤1: 解析视频\\\\n        setProgress(30);\\\\n        const parseUrl = `/api/parse?url=${encodeURIComponent(url)}`;\\\\n        const parseResp = await fetch(parseUrl);\\\\n\\\\n        if (!parseResp.ok) {\\\\n            const err = await parseResp.json();\\\\n            throw new Error(err.detail || '解析失败');\\\\n        }\\\\n\\\\n        const videoInfo = await parseResp.json();\\\\n        currentVideoInfo = videoInfo;\\\\n        currentVideoUrl = videoInfo.video_url;\\\\n\\\\n        setProgress(60);\\\\n        setStatus('正在获取视频文件...');\\\\n\\\\n        // 步骤2: 显示预览\\\\n        previewVideo.src = videoInfo.video_url;\\\\n        videoTitle.textContent = videoInfo.title || '抖音视频';\\\\n        videoMeta.textContent = `作者: ${videoInfo.author || '未知'}`;\\\\n\\\\n        setProgress(80hed);\\\\n        setStatus('准备下载...');\\\\n\\\\n        // 显示结果\\\\n        showResult(true);\\\\n        showStatus(false);\\\\n\\\\n        // 添加历史记录\\\\n        addHistory(videoInfo.title, url);\\\\n\\\\n        showToast('视频解析成功！');\\\\n\\\\n    } catch (error) {\\\\n        showStatus(true);\\\\n        setStatus(error.message || '解析失败，请检查链接是否正确', true);\\\\n        setProgress(0);\\\\n        showToast('解析失败: ' + (error.message || '未知错误'), 3000);\\\\n    } finally {\\\\n        isDownloading = false;\\\\n        downloadBtn.disabled = false;\\\\n        downloadBtn.querySelector('.btn-text').textContent = '解析并下载';\\\\n    }\\\\n}\\\\n\\\\n/**\\\\n * 保存视频到本地\\\\n */\\\\nasync function saveVideo() {\\\\n    if (!currentVideoUrl) {\\\\n        showToast('没有可下载的视频');\\\\n        return;\\\\n    }\\\\n\\\\n    saveBtn.disabled = true;\\\\n    saveBtn.innerHTML = `\\\\n        \\\\u003cdiv class=\\\\\\\"spinner\\\\\\\" style=\\\\\\\"width:18px;height:18px;border-width:2px;\\\\\\\"\\\\u003e\\\\u003c/div\\\\u003e\\\\n        下载中...\\\\n    `;\\\\n\\\\n    try {\\\\n        const title = currentVideoInfo?.title || '抖音视频';\\\\n        const downloadUrl = `/api/download?url=${encodeURIComponent(currentVideoUrl)}\\\\u0026title=${encodeURIComponent(title)}`;\\\\n\\\\n        // 创建下载链接\\\\n        const a = document.createElement('a');\\\\n        a.href = downloadUrl;\\\\n        a.download = '';\\\\n        document.body.appendChild(a);\\\\n        a.click();\\\\n        document.body.removeChild(a);\\\\n\\\\n        showToast('视频下载已开始！');\\\\n    } catch (error) {\\\\n        showToast('下载失败: ' + (error.message || '未知错误'), 3000);\\\\n    } finally {\\\\n        saveBtn.disabled = false;\\\\n        saveBtn.innerHTML = `\\\\n            \\\\u003csvg viewBox=\\\\\\\"0 0 24 24\\\\\\\" width=\\\\\\\"20\\\\\\\" height=\\\\\\\"20\\\\\\\"\\\\u003e\\\\n                \\\\u003cpath fill=\\\\\\\"currentColor\\\\\\\" d=\\\\\\\"M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z\\\\\\\"/\\\\u003e\\\\n            \\\\u003c/svg\\\\u003e\\\\n            保存到本地\\\\n        `;\\\\n    }\\\\n}\\\\n\\\\n/**\\\\n * 复制视频链接\\\\n */\\\\nfunction copyVideoLink() {\\\\n    if (!currentVideoUrl) {\\\\n        showToast('没有可复制的链接');\\\\n        return;\\\\n    }\\\\n\\\\n    navigator.clipboard.writeText(currentVideoUrl).then(() =\\\\u003e {\\\\n        showToast('视频链接已复制！');\\\\n    }).catch(() =\\\\u003e {\\\\n        // 降级方案\\\\n        const textarea = document.createElement('textarea');\\\\n        textarea.value = currentVideoUrl;\\\\n        document.body.appendChild(textarea);\\\\n        textarea.select();\\\\n        document.execCommand('copy');\\\\n        document.body.removeChild(textarea);\\\\n        showToast('视频链接已复制！');\\\\n    });\\\\n}\\\\n\\\\n// ========== 事件绑定 ==========\\\\n\\\\n// 下载按钮点击\\\\ndownloadBtn.addEventListener('click', () =\\\\u003e {\\\\n    const url = videoUrlInput.value.trim();\\\\n    if (!url) {\\\\n        showToast('请输入抖音分享链接');\\\\n        videoUrlInput.focus();\\\\n        return;\\\\n    }\\\\n    startDownload(url);\\\\n});\\\\n\\\\n// 输入框变化\\\\nvideoUrlInput.addEventListener('input', () =\\\\u003e {\\\\n    clearBtn.style.display = videoUrlInput.value ? 'block' : 'none';\\\\n});\\\\n\\\\n// 清空按钮\\\\nclearBtn.addEventListener('click', () =\\\\u003e {\\\\n    videoUrlInput.value = '';\\\\n    clearBtn.style.display = 'none';\\\\n    videoUrlInput.focus();\\\\n});\\\\n\\\\n// 保存按钮\\\\nsaveBtn.addEventListener('click', saveVideo);\\\\n\\\\n// 复制按钮\\\\ncopyBtn.addEventListener('click', copyVideoLink);\\\\n\\\\n// 清空历史\\\\nclearHistoryBtn.addEventListener('click', () =\\\\u003e {\\\\n    if (confirm('确定清空所有下载记录吗？')) {\\\\n        localStorage.removeItem('douyin_download_history');\\\\n        renderHistory([]);\\\\n        showToast('历史记录已清空');\\\\n    }\\\\n});\\\\n\\\\n// 回车键触发下载\\\\nvideoUrlInput.addEventListener('keydown', (e) =\\\\u003e {\\\\n    if (e.key === 'Enter') {\\\\n        downloadBtn.click();\\\\n    }\\\\n});\\\\n\\\\n// ========== 初始化 ==========\\\\nloadHistory();\\\\n\\\\n// 检查是否有粘贴的链接（从剪贴板）\\\\ndocument.addEventListener('paste', () =\\\\u003e {\\\\n    setTimeout(() =\\\\u003e {\\\\n        const url = videoUrlInput.value.trim();\\\\n        if (url \\\\u0026\\\\u0026 (url.includes('douyin.com') || url.includes('v.douyin.com'))) {\\\\n            clearBtn.style.display = 'block';\\\\n        }\\\\n    }, 100);\\\\n});\\\\n\\\"}\",\"note\":\"\"}","role":"tool","tool_call_id":"call_70d5388827e44099a8d337c7","tool_call_name":"read_file"}],"request_id":"68436cd614414e3d94b18df8ee93db53"}	{"request_id": "68436cd614414e3d94b18df8ee93db53", "username": "v_yxiochen", "pid": 35384}
