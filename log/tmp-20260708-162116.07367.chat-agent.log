<script>
const videoUrlInput=document.getElementById('videoUrl'),clearBtn=document.getElementById('clearBtn'),downloadBtn=document.getElementById('downloadBtn'),statusSection=document.getElementById('statusSection'),statusText=document.getElementById('statusText'),statusIcon=document.getElementById('statusIcon'),progressFill=document.getElementById('progressFill'),resultSection=document.getElementById('resultSection'),previewVideo=document.getElementById('previewVideo'),videoTitle=document.getElementById('videoTitle'),videoMeta=document.getElementById('videoMeta'),saveBtn=document.getElementById('saveBtn'),copyBtn=document.getElementById('copyBtn'),historyList=document.getElementById('historyList'),clearHistoryBtn=document.getElementById('clearHistoryBtn');
let currentVideoUrl='',currentVideoInfo=null,isDownloading=false;
function showToast(msg,duration=2000){const e=document.querySelector('.toast');if(e)e.remove();const t=document.createElement('div');t.className='toast',t.textContent=msg,document.body.appendChild(t),requestAnimationFrame(()=>{t.classList.add('show')}),setTimeout(()=>{t.classList.remove('show'),setTimeout(()=>t.remove(),300)},duration)}
function formatTime(e){const t=new Date,n=t-e,o=Math.floor(n/6e4),i=Math.floor(n/36e5),r=Math.floor(n/864e5);return o<1?'刚刚':o<60?o+'分钟前':i<24?i+'小时前':r<7?r+'天前':e.toLocaleDateString('zh-CN')}
function setStatus(e,t=!1){statusText.textContent=e,statusText.className='status-text'+(t?' error-text':''),t?statusIcon.innerHTML='<svg viewBox="0 0 24 24" width="32" height="32" style="color:#ff5252"><path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>':statusIcon.innerHTML='<div class="spinner"></div>'}
function setProgress(e){progressFill.style.width=e+'%'}
function showStatus(e){statusSection.style.display=e?'block':'none'}
function showResult(e){resultSection.style.display=e?'block':'none'}
function loadHistory(){try{const e=JSON.parse(localStorage.getItem('douyin_download_history')||'[]');renderHistory(e)}catch{renderHistory([])}}
function escapeHtml(e){const t=document.createElement('div');return t.textContent=e,t.innerHTML}
function renderHistory(e){if(0===e.length){historyList.innerHTML='<div class="empty-history">暂无下载记录</div>';return}
historyList.innerHTML=e.map((e,t)=>'<div class="history-item" data-index="'+t+'"><div class="history-thumb"><svg viewBox="0 0 24 24" width="24" height="24" fill="#666"><path d="M8 5v14l11-7z"/></svg></div><div class="history-info"><div class="history-name">'+escapeHtml(e.title||'抖音视频')+'</div><div class="history-time">'+formatTime(new Date(e.time))+'</div></div><button class="history-delete" data-index="'+t+'" onclick="event.stopPropagation();deleteHistory('+t+')"><svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg></button></div>').join('');
document.querySelectorAll('.history-item').forEach(e=>{e.addEventListener('click',function(){const t=parseInt(this.dataset.index),n=JSON.parse(localStorage.getItem('douyin_download_history')||'[]'),o=n[t];o&&o.url&&(videoUrlInput.value=o.url,clearBtn.style.display='block',startDownload(o.url))})})}
function addHistory(e,t){try{const n=JSON.parse(localStorage.getItem('douyin_download_history')||'[]');n.some(e=>e.url===t)||(n.unshift({title:e,url:t,time:new Date().toISOString()}),n.length>20&&n.pop(),localStorage.setItem('douyin_download_history',JSON.stringify(n)),renderHistory(n))}catch{}}
function deleteHistory(e){try{const t=JSON.parse(localStorage.getItem('douyin_download_history')||'[]');t.splice(e,1),localStorage.setItem('douyin_download_history',JSON.stringify(t)),renderHistory(t)}catch{}}
async function startDownload(e){if(isDownloading)return;isDownloading=!0,downloadBtn.disabled=!0,downloadBtn.querySelector('.btn-text').textContent='解析中...',showStatus(!0),showResult(!1),setStatus('正在解析视频链接...'),setProgress(10);try{setProgress(30);const t=await fetch('/api/parse?url='+encodeURIComponent(e));if(!t.ok){const n=await t.json();throw new Error(n.detail||'解析失败')}const n=await t.json();currentVideoInfo=n,currentVideoUrl=n.video_url,setProgress(60),setStatus('正在获取视频文件...'),previewVideo.src=n.video_url,videoTitle.textContent=n.title||'抖音视频',videoMeta.textContent='作者: '+(n.author||'未知'),setProgress(80),setStatus('准备下载...'),showResult(!0),showStatus(!1),addHistory(n.title,e),showToast('视频解析成功！')}catch(t){showStatus(!0),setStatus(t.message||'解析失败，请检查链接是否正确',!0),setProgress(0),showToast('解析失败: '+(t.message||'未知错误'),3e3)}finally{isDownloading=!1,downloadBtn.disabled=!1,downloadBtn.querySelector('.btn-text').textContent='解析并下载'}}
async function saveVideo(){if(!currentVideoUrl){showToast('没有可下载的视频');return}
saveBtn.disabled=!0,saveBtn.innerHTML='<div class="spinner" style="width:18px;height:18px;border-width:2px;"></div> 下载中...';try{const e=currentVideoInfo?.title||'抖音视频',t='/api/download?url='+encodeURIComponent(currentVideoUrl)+'&title='+encodeURIComponent(e),n=document.createElement('a');n.href=t,document.body.appendChild(n),n.click(),document.body.removeChild(n),showToast('视频下载已开始！')}catch(e){showToast('下载失败: '+(e.message||'未知错误'),3e3)}finally{saveBtn.disabled=!1,saveBtn.innerHTML='<svg viewBox="0 0 24 24" width="20" height="20"><path fill="currentColor" d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg> 保存到本地'}}
function copyVideoLink(){currentVideoUrl?(navigator.clipboard.writeText(currentVideoUrl).then(()=>{showToast('视频链接已复制！')}).catch(()=>{const e=document.createElement('textarea');e.value=currentVideoUrl,document.body.appendChild(e),e.select(),document.execCommand('copy'),document.body.removeChild(e),showToast('视频链接已复制！')})):showToast('没有可复制的链接')}
downloadBtn.addEventListener('click',()=>{const e=videoUrlInput.value.trim();e?startDownload(e):(showToast('请输入抖音分享链接'),videoUrlInput.focus())});
videoUrlInput.addEventListener('input',()=>{clearBtn.style.display=videoUrlInput.value?'block':'none'});
clearBtn.addEventListener('click',()=>{videoUrlInput.value='',clearBtn.style.display='none',videoUrlInput.focus()});
saveBtn.addEventListener('click',saveVideo);
copyBtn.addEventListener('click',copyVideoLink);
clearHistoryBtn.addEventListener('click',()=>{confirm('确定清空所有下载记录吗？')&&(localStorage.removeItem('douyin_download_history'),renderHistory([]),showToast('历史记录已清空'))});
videoUrlInput.addEventListener('keydown',e=>{'Enter'===e.key&&downloadBtn.click()});
loadHistory();
document.addEventListener('paste',()=>{setTimeout(()=>{const e=videoUrlInput.value.trim();e&&(e.includes('douyin.com')||e.includes('v.douyin.com'))&&(clearBtn.style.display='block')},100)});
</script>
</body>
</html>

